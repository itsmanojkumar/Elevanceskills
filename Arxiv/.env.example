# ============================================================
# ArXiv Expert Chatbot - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# LLM Backend: ollama | groq | huggingface
LLM_BACKEND=huggingface

# --- Ollama (local) ---
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# --- Groq (free cloud API) ---
# Get key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- HuggingFace (free cloud API) ---
# Get key at: https://huggingface.co/settings/tokens
HF_API_KEY=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# --- Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- ArXiv ---
# Default category for paper fetching
DEFAULT_CATEGORY=cs
# Number of papers to fetch on initial load
INITIAL_PAPER_COUNT=200

# --- App ---
APP_TITLE=ArXiv Expert Chatbot
