# Unified Chatbot Platform - backend environment template
# Copy this file to `.env` in the repo root and fill values as needed.

# --------------------------------------------------------------------
# Task 2 — Multimodal (Gemini)
# --------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --------------------------------------------------------------------
# Task 5 — Arxiv backend selection (optional global defaults)
# Arxiv reads its own `Arxiv/.env` first for task-specific config.
# Keep these here if you want shared/global defaults.
# --------------------------------------------------------------------
LLM_BACKEND=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

HF_API_KEY=
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# --------------------------------------------------------------------
# Task 1 — Dynamic KB: no API key required
# Task 3 — Sentiment: no API key required
# Task 4 — Multilingual: no API key required
# Task 6 — Medical Chatbot: no API key required
# --------------------------------------------------------------------
